{
  "name": "personal-web",
  "type": "module",
  "version": "1.0.0",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "npm run last-modified && astro build",
    "last-modified": "node --experimental-strip-types scripts/generate-last-modified.ts",
    "preview": "astro preview",
    "preview:ci": "astro preview --host 127.0.0.1 --port 4322",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test:a11y",
    "check:fix": "npm run lint:fix && npm run format",
    "typecheck": "astro check",
    "test:a11y": "npm run build && (npx http-server dist -p 4324 -s & npx wait-on http://localhost:4324 && npx pa11y-ci && pkill -f 'http-server dist -p 4324')",
    "test:a11y:ci": "(npx http-server dist -p 4324 -s & npx wait-on http://localhost:4324 && npx pa11y-ci)",
    "test:unit": "node --experimental-strip-types --experimental-test-module-mocks --import ./scripts/test-setup.mjs --test 'tests/unit/**/*.test.ts'",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium firefox webkit",
    "size:check": "node ./scripts/check-bundle-size.mjs",
    "lighthouse:ci": "CHROME_PATH=\"$(node ./scripts/chrome-path.mjs)\" lhci autorun --config=./lighthouserc.json",
    "extract-lighthouse": "node --experimental-strip-types scripts/extract-lighthouse.ts",
    "postinstall": "npm run hooks:install",
    "hooks:install": "node ./scripts/install-hooks.mjs",
    "clean": "rm -rf dist node_modules/.vite .astro",
    "deploy": "npm run build && sh scripts/deploy.sh"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@iconify-json/lucide": "^1.2.100",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.1",
    "astro-compressor": "^1.3.0",
    "astro-icon": "^1.1.5",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@cspell/dict-cs-cz": "^3.0.8",
    "@iconify-json/simple-icons": "^1.2.76",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "cspell": "^9.7.0",
    "eslint": "^10.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "http-server": "^14.1.1",
    "pa11y-ci": "^4.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.58.0",
    "wait-on": "^9.0.5"
  },
  "overrides": {
    "@astrojs/check": {
      "typescript": "$typescript"
    },
    "tmp": "^0.2.5"
  }
}
