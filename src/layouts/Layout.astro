---
import { SEO } from 'astro-seo';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Anna Zezulka | Software Architect',
  image = '/og-image.jpg', // TODO: replace with actual image
} = Astro.props;

const currentLang = Astro.currentLocale || 'en';
---

<!doctype html>
<html lang={currentLang} class="antialiased selection:bg-zinc-300 selection:text-zinc-900">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <SEO
      title={title}
      description={description}
      openGraph={{
        basic: {
          title: title,
          type: 'website',
          image: new URL(image, Astro.site || Astro.url).toString(),
        },
      }}
    />
  </head>
  <body class="min-h-screen bg-zinc-50 text-zinc-900 transition-colors duration-1000">
    <slot />
  </body>
</html>
