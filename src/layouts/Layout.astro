---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { langPrefixRegex, supportedLangs, type LanguageCode } from '../i18n/dictionary';
import { useTranslations } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  lang?: LanguageCode;
  noIndex?: boolean;
}

const { title, description, lang = 'en', noIndex = false } = Astro.props;
const t = useTranslations(lang);
const siteName = t('site.name');
const pageDescription = description ?? siteName;

const normalizedTitle = title?.trim();
const pageTitle = normalizedTitle
  ? normalizedTitle.includes(siteName)
    ? normalizedTitle
    : `${normalizedTitle} | ${siteName}`
  : siteName;

const pathname = Astro.url.pathname;
// langPrefixRegex matches either `/en/` or `/en` (at string end)
// To cleanly remove the language prefix from the path, we can strip the matching prefix
// and ensure it starts with a slash.
const match = langPrefixRegex.exec(pathname);
const pathWithoutLang = match ? pathname.slice(match[0].length).replace(/^\/?/, '/') : pathname;
const siteUrl = Astro.site ?? Astro.url;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; form-action 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self';"
    />
    <meta name="referrer" content="no-referrer" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <ClientRouter />
    <script is:inline>
      const root = document.documentElement;

      const getPreferredTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      };

      const applyPreferredTheme = () => {
        const theme = getPreferredTheme();
        if (theme === 'dark') {
          root.classList.add('dark');
          root.style.colorScheme = 'dark';
        } else {
          root.classList.remove('dark');
          root.style.colorScheme = 'light';
        }
      };

      applyPreferredTheme();
      window.__applyPreferredTheme = applyPreferredTheme;
    </script>
    <script>
      const _window = window as Window & {
        __themeAfterSwapBound?: boolean;
        __applyPreferredTheme?: () => void;
      };

      // Astro view transitions can swap DOM state; re-apply persisted theme right after swap.
      if (!_window.__themeAfterSwapBound) {
        document.addEventListener('astro:after-swap', () => {
          if (_window.__applyPreferredTheme) _window.__applyPreferredTheme();
        });
        _window.__themeAfterSwapBound = true;
      }
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.jpg" />
    {noIndex && <meta name="robots" content="noindex" />}
    <slot name="head" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {
      supportedLangs.map(l => (
        <link rel="alternate" hreflang={l} href={new URL(`/${l}${pathWithoutLang}`, siteUrl)} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={siteUrl} />
  </head>
  <body data-print-banner={t('print.banner')}>
    <div id="arch" hidden aria-hidden="true"></div>
    <div id="audit" hidden aria-hidden="true"></div>
    <div id="layers" hidden aria-hidden="true"></div>
    <div id="page-shell">
      <a href="#main-content" class="skip-link">{t('layout.skipToMain')}</a>
      <slot />
    </div>
    <script>
      let cleanupLayers: (() => void) | null = null;

      const checkLayers = async () => {
        if (window.location.hash === '#layers') {
          if (!cleanupLayers) {
            const { initLayersMode } = await import('../scripts/layers');
            // Re-check hash after dynamic import to prevent race conditions
            if (window.location.hash !== '#layers' || cleanupLayers) {
              return;
            }
            cleanupLayers = initLayersMode() || null;
          }
        } else {
          if (cleanupLayers) {
            cleanupLayers();
            cleanupLayers = null;
          }
        }
      };

      // Ensure the listener is only attached once
      window.addEventListener('hashchange', checkLayers);

      document.addEventListener('astro:page-load', () => {
        // Track the current #page-shell instance. If it changes due to
        // Astro View Transitions while layers are active, force a reset
        // and re-initialization so listeners bind to the new DOM.
        if (cleanupLayers && window.location.hash === '#layers') {
          cleanupLayers();
          cleanupLayers = null;
        }
        checkLayers();
      });
    </script>
  </body>
</html>
