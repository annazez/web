---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { langPrefixRegex, supportedLangs, type LanguageCode } from '../i18n/dictionary';
import { useTranslations, localeForOg } from '../i18n/utils';
import { SITE_CSP, THEME_BOOTSTRAP_SCRIPT } from '../data/csp';
import DottedBackground from '../components/DottedBackground.astro';
import HeaderNav from '../components/ui/HeaderNav.astro';

interface Props {
  title?: string;
  description?: string;
  lang?: LanguageCode;
  noIndex?: boolean;
  ogImage?: string;
}

const { title, description, lang = 'en', noIndex = false, ogImage } = Astro.props;
const t = await useTranslations(lang);
const siteName = t('site.name');
const pageDescription = description ?? siteName;

const normalizedTitle = title?.trim();
const pageTitle = normalizedTitle
  ? normalizedTitle.includes(siteName)
    ? normalizedTitle
    : `${normalizedTitle} | ${siteName}`
  : siteName;

const pathname = Astro.url.pathname;
const siteUrl = Astro.site ?? Astro.url;
// langPrefixRegex matches either `/en/` or `/en` (at string end)
const match = langPrefixRegex.exec(pathname);
const pathWithoutLang = match ? pathname.slice(match[0].length).replace(/^\/?/, '/') : pathname;

const canonicalUrl = new URL(pathname, siteUrl).toString();
const absoluteOgImage = new URL(ogImage ?? '/og-image.jpg', siteUrl).toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Security-Policy" content={SITE_CSP} />
    <meta name="referrer" content="no-referrer" />
    <!--
      The following headers are missing from meta tags because they must be set at the HTTP level:
      - Strict-Transport-Security
      - X-Frame-Options
      - X-Content-Type-Options
      - Permissions-Policy

      They are configured in astro.config.mjs for dev/preview and in public/_headers for supported hosts.
    -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <ClientRouter />
    <script is:inline set:html={THEME_BOOTSTRAP_SCRIPT} />
    <script>
      import { bindOnce } from '../scripts/bind-once';

      const _window = window as Window & {
        __applyPreferredTheme?: () => void;
      };

      // Astro view transitions can swap DOM state; re-apply persisted theme right after swap.
      bindOnce('theme-after-swap', () => {
        document.addEventListener('astro:after-swap', () => {
          if (_window.__applyPreferredTheme) _window.__applyPreferredTheme();
        });
      });
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    {/* Canonical */}
    <link rel="canonical" href={canonicalUrl} />

    {/* OpenGraph */}
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={localeForOg(lang)} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:alt" content={t('og.imageAlt')} />
    {/* TODO: Verify actual dimensions of og-image.jpg once created. Defaulting to 1200x630. */}
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={absoluteOgImage} />
    {noIndex && <meta name="robots" content="noindex" />}
    <slot name="head" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {
      supportedLangs.map(l => (
        <link rel="alternate" hreflang={l} href={new URL(`/${l}${pathWithoutLang}`, siteUrl)} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={siteUrl} />
  </head>
  <body data-print-banner={t('print.banner')}>
    <DottedBackground />
    <div id="page-shell">
      <a href="#main-content" class="skip-link">{t('layout.skipToMain')}</a>
      <HeaderNav />
      <slot />
    </div>
  </body>
</html>
