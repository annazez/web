---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { langPrefixRegex, supportedLangs, type LanguageCode } from '../i18n/dictionary';
import { useTranslations, localeForOg } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  lang?: LanguageCode;
  noIndex?: boolean;
  ogImage?: string;
}

const { title, description, lang = 'en', noIndex = false, ogImage } = Astro.props;
const t = useTranslations(lang);
const siteName = t('site.name');
const pageDescription = description ?? siteName;

const normalizedTitle = title?.trim();
const pageTitle = normalizedTitle
  ? normalizedTitle.includes(siteName)
    ? normalizedTitle
    : `${normalizedTitle} | ${siteName}`
  : siteName;

const pathname = Astro.url.pathname;
const siteUrl = Astro.site ?? Astro.url;
// langPrefixRegex matches either `/en/` or `/en` (at string end)
const match = langPrefixRegex.exec(pathname);
const pathWithoutLang = match ? pathname.slice(match[0].length).replace(/^\/?/, '/') : pathname;

const canonicalUrl = new URL(pathname, siteUrl).toString();
const absoluteOgImage = new URL(ogImage ?? '/og-image.jpg', siteUrl).toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; base-uri 'self'; object-src 'none'; form-action 'self'; script-src 'self' 'sha256-3SEKDv3sFH97ZKnC+vAKSes3RjKxxvGDZQ1fYOFGRtU='; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self';"
    />
    <meta name="referrer" content="no-referrer" />
    <!--
      The following headers are missing from meta tags because they must be set at the HTTP level:
      - Strict-Transport-Security
      - X-Frame-Options
      - X-Content-Type-Options
      - Permissions-Policy

      They are configured in astro.config.mjs for dev/preview and in public/_headers for supported hosts.
    -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <ClientRouter />
    <script is:inline>
      /**
       * THEME BOOTSTRAP:
       * This script must run synchronously before paint to prevent FOUC.
       * CSP: If this script is modified, the SHA-256 hash in Content-Security-Policy must be updated.
       * Hash: sha256-3SEKDv3sFH97ZKnC+vAKSes3RjKxxvGDZQ1fYOFGRtU=
       */
      const root = document.documentElement;

      const getPreferredTheme = () => {
        const storedTheme =
          typeof localStorage !== 'undefined' ? localStorage.getItem('theme') : null;
        if (storedTheme === 'dark' || storedTheme === 'light') {
          return storedTheme;
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };

      const applyPreferredTheme = () => {
        const theme = getPreferredTheme();
        if (theme === 'dark') {
          root.classList.add('dark');
          root.style.colorScheme = 'dark';
        } else {
          root.classList.remove('dark');
          root.style.colorScheme = 'light';
        }
      };

      applyPreferredTheme();
      window.__applyPreferredTheme = applyPreferredTheme;
    </script>
    <script>
      const _window = window as Window & {
        __themeAfterSwapBound?: boolean;
        __applyPreferredTheme?: () => void;
      };

      // Astro view transitions can swap DOM state; re-apply persisted theme right after swap.
      if (!_window.__themeAfterSwapBound) {
        document.addEventListener('astro:after-swap', () => {
          if (_window.__applyPreferredTheme) _window.__applyPreferredTheme();
        });
        _window.__themeAfterSwapBound = true;
      }
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    {/* Canonical */}
    <link rel="canonical" href={canonicalUrl} />

    {/* OpenGraph */}
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={localeForOg(lang)} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:alt" content={t('og.imageAlt')} />
    {/* TODO: Verify actual dimensions of og-image.jpg once created. Defaulting to 1200x630. */}
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={absoluteOgImage} />
    {noIndex && <meta name="robots" content="noindex" />}
    <slot name="head" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {
      supportedLangs.map(l => (
        <link rel="alternate" hreflang={l} href={new URL(`/${l}${pathWithoutLang}`, siteUrl)} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={siteUrl} />
  </head>
  <body data-print-banner={t('print.banner')}>
    <div id="arch" hidden aria-hidden="true"></div>
    <div id="audit" hidden aria-hidden="true"></div>
    <div id="layers" hidden aria-hidden="true"></div>
    <div id="page-shell">
      <a href="#main-content" class="skip-link">{t('layout.skipToMain')}</a>
      <slot />
    </div>
    <script>
      let cleanupLayers: (() => void) | null = null;

      const checkLayers = async () => {
        if (window.location.hash === '#layers') {
          if (!cleanupLayers) {
            const { initLayersMode } = await import('../scripts/layers');
            // Re-check hash after dynamic import to prevent race conditions
            if (window.location.hash !== '#layers' || cleanupLayers) {
              return;
            }
            cleanupLayers = initLayersMode() || null;
          }
        } else {
          if (cleanupLayers) {
            cleanupLayers();
            cleanupLayers = null;
          }
        }
      };

      // Ensure the listener is only attached once
      window.addEventListener('hashchange', checkLayers);

      document.addEventListener('astro:page-load', () => {
        // Track the current #page-shell instance. If it changes due to
        // Astro View Transitions while layers are active, force a reset
        // and re-initialization so listeners bind to the new DOM.
        if (cleanupLayers && window.location.hash === '#layers') {
          cleanupLayers();
          cleanupLayers = null;
        }
        checkLayers();
      });
    </script>
  </body>
</html>
