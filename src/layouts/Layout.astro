---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { supportedLangs } from '../i18n/dictionary';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  noIndex?: boolean;
}

const { title, description = 'Anna Zezulka', lang = 'en', noIndex = false } = Astro.props;
const siteName = 'Anna Zezulka';

const normalizedTitle = title?.trim();
const isAbsoluteRoot = Astro.url.pathname === '/';
const pageTitle = normalizedTitle
  ? normalizedTitle.includes(siteName)
    ? normalizedTitle
    : `${normalizedTitle} | ${siteName}`
  : isAbsoluteRoot
    ? siteName
    : siteName;

const langKeys = supportedLangs.join('|');
const langRegex = new RegExp(`^/(${langKeys})`);
const pathname = Astro.url.pathname;
const pathWithoutLang = pathname.replace(langRegex, '');
const siteUrl = Astro.site ?? Astro.url;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'sha256-OVhk/f/mfTM1dgnPcPK/gEx3VS+RFXqpWHAfIHZScXA=' 'sha256-In0vSEX5Tvt/QxQDMj4fkAfnRyo7fTjYLgA1CZKCz3Q='; style-src 'self'; style-src-elem 'self'; style-src-attr 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self';"
    />
    <link rel="preload" href="/theme-init.js" as="script" />
    <ClientRouter />
    <script is:inline src="/theme-init.js"></script>
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.jpg" />
    {noIndex && <meta name="robots" content="noindex" />}
    <slot name="head" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {
      supportedLangs.map(l => (
        <link rel="alternate" hreflang={l} href={new URL(`/${l}${pathWithoutLang}`, siteUrl)} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={siteUrl} />
  </head>
  <body>
    <div id="arch" class="hidden" aria-hidden="true"></div>
    <div id="audit" class="hidden" aria-hidden="true"></div>
    <div id="layers" class="hidden" aria-hidden="true"></div>
    <div id="page-shell">
      <a href="#main-content" class="skip-link">Skip to main content</a>
      <slot />
    </div>
    <script>
      let cleanupLayers: (() => void) | null = null;

      const checkLayers = async () => {
        if (window.location.hash === '#layers') {
          if (!cleanupLayers) {
            const { initLayersMode } = await import('../scripts/layers');
            // Re-check hash after dynamic import to prevent race conditions
            if (window.location.hash !== '#layers' || cleanupLayers) {
              return;
            }
            cleanupLayers = initLayersMode() || null;
          }
        } else {
          if (cleanupLayers) {
            cleanupLayers();
            cleanupLayers = null;
          }
        }
      };

      // Ensure the listener is only attached once
      window.addEventListener('hashchange', checkLayers);

      document.addEventListener('astro:page-load', () => {
        // Track the current #page-shell instance. If it changes due to
        // Astro View Transitions while layers are active, force a reset
        // and re-initialization so listeners bind to the new DOM.
        if (cleanupLayers && window.location.hash === '#layers') {
          cleanupLayers();
          cleanupLayers = null;
        }
        checkLayers();
      });
    </script>
  </body>
</html>
