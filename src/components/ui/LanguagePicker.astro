---
import { getLangFromUrl } from '../../i18n/utils';
import { languages, routes, languageEntries, type LanguageCode } from '../../i18n/dictionary';
import ThemeToggle from './ThemeToggle.astro';

const currentLang = getLangFromUrl(Astro.url);

const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const hasLangPrefix =
  pathSegments.length > 0 && Object.prototype.hasOwnProperty.call(languages, pathSegments[0]);
const routeSegments = hasLangPrefix ? pathSegments.slice(1) : pathSegments;

const localizedSlugSets: Array<Record<LanguageCode, string>> = [routes.workspace];

function mapLocalizedSegment(
  segment: string,
  fromLang: LanguageCode,
  toLang: LanguageCode
): string {
  for (const slugSet of localizedSlugSets) {
    if (segment === slugSet[fromLang]) {
      return slugSet[toLang];
    }
  }

  return segment;
}

function getLocalizedHref(targetLang: LanguageCode): string {
  if (routeSegments.length === 0) {
    return `/${targetLang}/`;
  }

  const localizedSegments = routeSegments.map(segment =>
    mapLocalizedSegment(segment, currentLang as LanguageCode, targetLang)
  );

  return `/${targetLang}/${localizedSegments.join('/')}`;
}
---

<nav aria-label="Language" class="absolute top-8 right-8 flex items-center gap-4">
  <div class="home-micro-label flex gap-4">
    {
      languageEntries.map(([code, label], index) => (
        <>
          <a
            href={getLocalizedHref(code)}
            data-lang-link="true"
            class={
              currentLang === code
                ? 'text-zinc-900 dark:text-zinc-100'
                : 'text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-500 dark:hover:text-zinc-100'
            }
          >
            {label}
          </a>
          {index < languageEntries.length - 1 && (
            <span class="text-zinc-400 dark:text-zinc-600">/</span>
          )}
        </>
      ))
    }
  </div>
  <ThemeToggle />
</nav>

<script>
  function showLanguageSwitchOverlay() {
    const overlay = document.createElement('div');
    overlay.className = 'theme-transition-overlay';

    const nextTheme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
    overlay.dataset.theme = nextTheme;

    document.body.appendChild(overlay);
    const animation = overlay.animate(
      [{ opacity: 0 }, { opacity: 1, offset: 0.5 }, { opacity: 0 }],
      {
        duration: 120,
        easing: 'linear',
        fill: 'forwards',
      }
    );

    animation.addEventListener('finish', () => overlay.remove(), { once: true });
  }

  document.querySelectorAll<HTMLAnchorElement>('a[data-lang-link="true"]').forEach(link => {
    link.addEventListener('click', event => {
      const href = link.getAttribute('href');

      if (!href || link.pathname === window.location.pathname) {
        return;
      }

      event.preventDefault();
      showLanguageSwitchOverlay();
      window.setTimeout(() => {
        window.location.href = href;
      }, 80);
    });
  });
</script>
