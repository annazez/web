---
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import {
  languages,
  languageEntries,
  buildRouteLookup,
  type LanguageCode,
} from '../../i18n/dictionary';
import { getAllProjectSlugSets } from '../../lib/projects';

const currentLang = getLangFromUrl(Astro.url);
const t = await useTranslations(currentLang);

// Source dynamic slug pairs from projects collection.
const projectSlugSets = await getAllProjectSlugSets();
const routeLookup = buildRouteLookup(projectSlugSets);

const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const hasLangPrefix =
  pathSegments.length > 0 && Object.prototype.hasOwnProperty.call(languages, pathSegments[0]);
const routeSegments = hasLangPrefix ? pathSegments.slice(1) : pathSegments;

function mapLocalizedSegment(
  segment: string,
  fromLang: LanguageCode,
  toLang: LanguageCode
): string {
  const slugSet = routeLookup.get(`${fromLang}:${segment}`);
  return slugSet ? slugSet[toLang] : segment;
}

function getLocalizedHref(targetLang: LanguageCode): string {
  if (routeSegments.length === 0) {
    return `/${targetLang}/`;
  }

  const localizedSegments = routeSegments.map(segment =>
    mapLocalizedSegment(segment, currentLang as LanguageCode, targetLang)
  );

  return `/${targetLang}/${localizedSegments.join('/')}`;
}
---

<details class="rolldown-menu group relative w-full sm:w-auto">
  <summary
    aria-label={`${t('ui.languageNavigation')}: ${languages[currentLang]}`}
    class="flex min-h-11 w-full cursor-pointer list-none items-center justify-between gap-2 rounded-xl border border-(--color-border) bg-(--color-bg) px-3 py-2 text-(--color-text-muted) shadow-sm transition-colors duration-200 group-open:bg-(--color-bg-surface) group-open:text-(--color-brand) hover:text-(--color-brand) sm:w-32 [&::-webkit-details-marker]:hidden"
  >
    <Icon name="lucide:globe" class="size-3.5 shrink-0" aria-hidden="true" />
    <span class="home-micro-label whitespace-nowrap">{languages[currentLang]}</span>
    <Icon
      name="lucide:chevron-down"
      class="size-4 shrink-0 transition-transform duration-200 group-open:rotate-180"
      aria-hidden="true"
    />
  </summary>

  <ul
    class="mt-2 rounded-lg border border-(--color-border) bg-(--color-bg-surface) p-1 shadow-sm sm:absolute sm:top-[calc(100%+0.4rem)] sm:right-0 sm:mt-0 sm:min-w-32"
  >
    {
      languageEntries.map(([code, label]) => (
        <li>
          <a
            href={getLocalizedHref(code)}
            aria-current={currentLang === code ? 'page' : undefined}
            aria-label={`${t('ui.languageNavigation')}: ${label}`}
            class={
              currentLang === code
                ? 'home-micro-label block rounded-md bg-(--color-bg) px-3 py-2 text-(--color-brand)'
                : 'home-micro-label block rounded-md px-3 py-2 text-(--color-text-muted) transition-colors hover:text-(--color-brand)'
            }
          >
            {label}
          </a>
        </li>
      ))
    }
  </ul>
</details>

<style>
  details.rolldown-menu > ul {
    display: block;
    max-height: 0;
    margin-top: 0;
    opacity: 0;
    overflow: hidden;
    pointer-events: none;
    transform: translateY(-0.3rem);
    transition:
      max-height 220ms ease,
      opacity 160ms ease,
      transform 220ms ease,
      margin-top 220ms ease;
  }

  details.rolldown-menu:global([open]) > ul {
    max-height: 12rem;
    margin-top: 0.5rem;
    opacity: 1;
    overflow: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  @media (min-width: 40rem) {
    details.rolldown-menu:global([open]) > ul {
      margin-top: 0;
    }
  }
</style>
