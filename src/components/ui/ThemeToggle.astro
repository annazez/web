---
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<button
  id="theme-toggle"
  aria-label={t('ui.themeToggle')}
  class="rounded-lg p-2 text-(--color-text-muted) transition-colors hover:text-(--color-brand)"
>
  <Icon name="lucide:sun" class="h-5 w-5" id="sun-icon" />
  <Icon name="lucide:moon" class="hidden h-5 w-5" id="moon-icon" />
</button>

<script>
  const themeWindow = window as Window & {
    __themePageLoadBound?: boolean;
    __themeSyncBound?: boolean;
  };
  const prefersDarkMedia = window.matchMedia('(prefers-color-scheme: dark)');

  function getPreferredTheme(): 'light' | 'dark' {
    const savedTheme = localStorage.getItem('theme');
    if (savedTheme === 'light' || savedTheme === 'dark') {
      return savedTheme;
    }
    return prefersDarkMedia.matches ? 'dark' : 'light';
  }

  // Apply theme and sync icon state for the current page DOM.
  function applyTheme(theme: 'light' | 'dark') {
    const html = document.documentElement;
    const sunIcon = document.getElementById('sun-icon');
    const moonIcon = document.getElementById('moon-icon');

    if (theme === 'dark') {
      html.classList.add('dark');
      html.style.colorScheme = 'dark';
      sunIcon?.classList.add('hidden');
      moonIcon?.classList.remove('hidden');
    } else {
      html.classList.remove('dark');
      html.style.colorScheme = 'light';
      sunIcon?.classList.remove('hidden');
      moonIcon?.classList.add('hidden');
    }
  }

  function toggleTheme() {
    const newTheme = (document.documentElement.classList.contains('dark') ? 'light' : 'dark') as
      | 'light'
      | 'dark';
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!document.startViewTransition || prefersReducedMotion) {
      applyTheme(newTheme);
      localStorage.setItem('theme', newTheme);
      return;
    }

    document.startViewTransition(() => {
      applyTheme(newTheme);
      localStorage.setItem('theme', newTheme);
    });
  }

  function bindThemeToggle() {
    const themeToggle = document.getElementById('theme-toggle');
    if (!themeToggle || themeToggle.dataset.bound === 'true') {
      return;
    }

    themeToggle.dataset.bound = 'true';
    themeToggle.addEventListener('click', () => {
      toggleTheme();
    });
  }

  function initThemeUI() {
    applyTheme(getPreferredTheme());
    bindThemeToggle();
  }

  initThemeUI();
  if (!themeWindow.__themePageLoadBound) {
    document.addEventListener('astro:page-load', initThemeUI);
    themeWindow.__themePageLoadBound = true;
  }

  // Listen for system theme changes
  if (!themeWindow.__themeSyncBound) {
    prefersDarkMedia.addEventListener('change', e => {
      const newTheme = (e.matches ? 'dark' : 'light') as 'light' | 'dark';
      localStorage.removeItem('theme'); // Clear saved preference to follow system
      applyTheme(newTheme);
    });

    // Keep theme in sync across tabs/windows and animate there too
    window.addEventListener('storage', e => {
      if (e.key !== 'theme') {
        return;
      }

      const prefersDarkNow = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const syncedTheme = (e.newValue || (prefersDarkNow ? 'dark' : 'light')) as 'light' | 'dark';
      applyTheme(syncedTheme);
    });

    themeWindow.__themeSyncBound = true;
  }
</script>
