---
import { Icon } from 'astro-icon/components';
import { useTranslations } from '../../i18n/utils';
import { defaultLang, routes, type LanguageCode } from '../../i18n/dictionary';

interface Props {
  lang?: LanguageCode;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const lastUpdated = new Date().toLocaleDateString(lang === 'cs' ? 'cs-CZ' : 'en-GB', {
  year: 'numeric',
  month: 'long',
});
---

<footer
  class="flex w-full flex-wrap items-center gap-x-6 gap-y-3 border-t border-(--color-border) pt-8"
>
  <div class="flex items-center gap-6">
    <a
      href={`/${lang}/${routes.workspace[lang]}`}
      aria-label={t('hero.inventory')}
      title={t('hero.inventory')}
      class="text-(--color-text-muted) transition-colors hover:text-(--color-brand)"
      ><Icon name="lucide:laptop-minimal" class="h-5 w-5" /></a
    >
    <a
      href="https://codeberg.org/annazez/pages"
      target="_blank"
      rel="me noopener noreferrer"
      aria-label="Source code on Codeberg"
      title="Source code on Codeberg"
      class="text-(--color-text-muted) transition-colors hover:text-(--color-brand)"
      ><Icon name="lucide:code-2" class="h-5 w-5" /></a
    >
    <a
      href="/humans.txt"
      aria-label="Humans.txt"
      title="Humans.txt"
      class="text-(--color-text-muted) transition-colors hover:text-(--color-brand)"
      ><Icon name="lucide:file-text" class="h-5 w-5" /></a
    >
    <a
      href="/pgp/public-key.asc"
      aria-label="PGP public key"
      title="PGP public key"
      class="text-(--color-text-muted) transition-colors hover:text-(--color-brand)"
      ><Icon name="lucide:key-round" class="h-5 w-5" /></a
    >

    <a
      href="/cv.pdf"
      download
      aria-label={t('footer.downloadCv')}
      title={t('footer.downloadCv')}
      class="text-(--color-text-muted) transition-colors hover:text-(--color-brand)"
      ><Icon name="lucide:file-down" class="h-5 w-5" /></a
    >
  </div>

  <div
    class="home-micro-copy flex w-full flex-col gap-1 sm:ml-auto sm:w-auto sm:items-end sm:text-right"
  >
    <p class="home-body-text">{t('footer.lastUpdated')} {lastUpdated}</p>
    <p data-carbon-footprint>
      <span>{t('footer.carbonFootprint')}</span>
      <span
        id="carbon-footprint-value"
        data-loading={t('footer.loading')}
        data-timeout-ms="5000"
        style="display:inline-block;min-height:1.25em"
      >
        {t('footer.loading')}</span
      >
    </p>
  </div>

  <script src="../../scripts/carbon-footprint.ts"></script>
</footer>
