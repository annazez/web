---
import { Icon } from 'astro-icon/components';
import { useTranslations, localeFor } from '../../i18n/utils';
import { defaultLang, type LanguageCode } from '../../i18n/dictionary';
import { identity } from '../../data/identity';
import { toSafeExternalUrl } from '../../security/external-links';
import siteModified from '../../data/site-modified.json';

interface Props {
  lang?: LanguageCode;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const qualityHref = `/${lang}/quality/`;
const lastUpdatedDateTime = siteModified.lastModified;
const lastUpdated = new Date(lastUpdatedDateTime).toLocaleDateString(localeFor(lang), {
  year: 'numeric',
  month: 'long',
});

const codebergPagesUrl = toSafeExternalUrl(identity.codebergPages);
---

<footer
  class="flex w-full flex-wrap items-center gap-x-6 gap-y-3 border-t border-(--color-border) pt-8"
>
  <nav aria-label={t('footer.navigation')} class="flex items-center gap-6">
    <a
      href={qualityHref}
      aria-label={t('footer.siteQuality')}
      title={t('footer.siteQuality')}
      class="text-(--color-text-muted) transition-colors hover:text-(--color-brand)"
      ><Icon name="lucide:gauge" class="h-5 w-5" /></a
    >
    {
      codebergPagesUrl && (
        <a
          href={codebergPagesUrl}
          target="_blank"
          rel="me noopener noreferrer"
          aria-label={t('footer.sourceCode')}
          title={t('footer.sourceCode')}
          class="text-(--color-text-muted) transition-colors hover:text-(--color-brand)"
        >
          <Icon name="lucide:code-2" class="h-5 w-5" />
        </a>
      )
    }
    <a
      href="/humans.txt"
      aria-label={t('footer.humansTxt')}
      title={t('footer.humansTxt')}
      class="text-(--color-text-muted) transition-colors hover:text-(--color-brand)"
      ><Icon name="lucide:file-text" class="h-5 w-5" /></a
    >
    <a
      href="/pgp/public-key.asc"
      aria-label={t('footer.pgpPublicKey')}
      title={t('footer.pgpPublicKey')}
      class="text-(--color-text-muted) transition-colors hover:text-(--color-brand)"
      ><Icon name="lucide:key-round" class="h-5 w-5" /></a
    >
    <a
      href={`/${lang}/uses/`}
      aria-label={t('footer.uses')}
      title={t('footer.uses')}
      class="text-(--color-text-muted) transition-colors hover:text-(--color-brand)"
      ><Icon name="lucide:laptop" class="h-5 w-5" /></a
    >
    <a
      href={`/${lang}/architecture-decisions/`}
      aria-label={t('footer.adrs')}
      title={t('footer.adrs')}
      class="text-(--color-text-muted) transition-colors hover:text-(--color-brand)"
      ><Icon name="lucide:scroll-text" class="h-5 w-5" /></a
    >
  </nav>

  <div
    class="home-micro-copy flex w-full flex-col gap-1 sm:ml-auto sm:w-auto sm:items-end sm:text-right"
  >
    <p class="home-body-text">
      {t('footer.lastUpdated')}
      <time datetime={lastUpdatedDateTime}>{lastUpdated}</time>
    </p>
    <p data-carbon-footprint>
      <span>{t('footer.carbonFootprint')}</span>
      <span id="carbon-footprint-value" data-loading={t('footer.loading')} data-timeout-ms="5000">
        {t('footer.loading')}</span
      >
    </p>
  </div>

  <script src="../../scripts/carbon-footprint.ts"></script>
</footer>
