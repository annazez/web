---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="flex flex-col gap-16">
  <header class="flex flex-col gap-4">
    <h1 class="text-4xl font-light tracking-tight text-zinc-900 sm:text-5xl">Anna Zezulka</h1>
    <p class="font-mono text-sm tracking-widest text-zinc-500 uppercase">{t('role.title')}</p>
  </header>
  <section class="space-y-6 leading-relaxed text-zinc-600">
    <p>{t('hero.manifesto')}</p>
    <p>
      {t('hero.status')}
      <span class="font-medium text-zinc-900">{t('hero.layer')}</span>
      {t('hero.layerSuffix')}
    </p>
  </section>
</div>
