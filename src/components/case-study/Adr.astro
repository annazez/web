---
/**
 * Adr Component
 *
 * Renders a single ADR entry from the adrs content collection.
 * Used in case study MDX files to avoid content duplication — the ADR
 * text lives in the collection and is rendered identically everywhere.
 */
import { getCollection } from 'astro:content';
import { getLangFromUrl } from '../../i18n/utils';

interface Props {
  id: string;
}

const { id } = Astro.props;
const lang = getLangFromUrl(Astro.url);

const allAdrs = await getCollection('adrs', ({ data }) => data.id === id && data.lang === lang);
const adr = allAdrs[0];

if (!adr) {
  throw new Error(`ADR not found: id="${id}", lang="${lang}"`);
}

const { title, context, decision, consequences } = adr.data;
---

<div class="adr-entry">
  <h3>{`${id.toUpperCase().replace(/-(\d+)$/, '-$1')}: ${title}`}</h3>

  <p><strong>{lang === 'cs' ? 'Kontext:' : 'Context:'}</strong> {context}</p>

  <p><strong>{lang === 'cs' ? 'Rozhodnutí:' : 'Decision:'}</strong> {decision}</p>

  <p><strong>{lang === 'cs' ? 'Důsledky:' : 'Consequences:'}</strong> {consequences}</p>
</div>
