---
/**
 * SECTION CONVENTION:
 * This component self-wraps its "card chrome" (background, border, shadow).
 * This ensures visual consistency across the site and simplifies page layouts.
 */
import placeholderData from '../data/lighthouse.localhost.json';
import lighthouseData from '../data/lighthouse.json';
import type { LighthouseData, ScoreKey, MetricKey } from '../types/lighthouse';
import { getLangFromUrl, useTranslations, localeFor } from '../i18n/utils';
import Surface from './ui/Surface.astro';

const isLocalhost = Astro.url.hostname === 'localhost' || Astro.url.hostname === '127.0.0.1';
const data = (isLocalhost ? placeholderData : lighthouseData) as LighthouseData;
const lang = getLangFromUrl(Astro.url);
const t = await useTranslations(lang);
const locale = localeFor(lang);
const pages = [...(data.pages ?? [])].sort((a, b) => a.path.localeCompare(b.path));
const selectedPage = pages[0] ?? null;
const hasData = pages.length > 0;

const measuredAt = data.generatedAt ? new Date(data.generatedAt) : null;
const measuredAtLabel =
  measuredAt && !Number.isNaN(measuredAt.getTime())
    ? measuredAt.toLocaleString(locale)
    : t('quality.noSnapshot');

const scoreDefinitions: ReadonlyArray<{ key: ScoreKey; label: string }> = [
  { key: 'performance', label: t('quality.performance') },
  { key: 'accessibility', label: t('quality.accessibility') },
  { key: 'bestPractices', label: t('quality.bestPractices') },
  { key: 'seo', label: t('quality.seo') },
];

const metricDefinitions: ReadonlyArray<{
  key: MetricKey;
  label: string;
  fullLabel: string;
}> = [
  { key: 'lcp', label: 'LCP', fullLabel: t('quality.metrics.lcp') },
  { key: 'tbt', label: 'TBT', fullLabel: t('quality.metrics.tbt') },
  { key: 'cls', label: 'CLS', fullLabel: t('quality.metrics.cls') },
  { key: 'fcp', label: 'FCP', fullLabel: t('quality.metrics.fcp') },
  { key: 'ttfb', label: 'TTFB', fullLabel: t('quality.metrics.ttfb') },
];

const formatTimestamp = (value: string | null): string => {
  if (!value) {
    return t('quality.na');
  }

  const parsed = new Date(value);
  return Number.isNaN(parsed.getTime()) ? value : parsed.toLocaleString(locale);
};

const resultsByPath = Object.fromEntries(pages.map(page => [page.path, page]));
const resultsByPathData = JSON.stringify(resultsByPath);

const i18nData = JSON.stringify({
  na: t('quality.na'),
  noSnapshot: t('quality.noSnapshot'),
  locale,
});

const scoreClassName = (score: number | null): string => {
  if (score === null) {
    return 'bg-stone-100 text-stone-700 ring-stone-200';
  }

  if (score >= 90) {
    return 'bg-emerald-100 text-emerald-800 ring-emerald-200';
  }

  if (score >= 50) {
    return 'bg-amber-100 text-amber-800 ring-amber-200';
  }

  return 'bg-rose-100 text-rose-800 ring-rose-200';
};
---

{
  (
    <Surface as="section" data-lighthouse-dashboard>
      <script type="application/json" data-results set:html={resultsByPathData} />
      <script type="application/json" data-i18n set:html={i18nData} />
      <header class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
          <h2>Lighthouse CI</h2>
          {data.generatedAt ? (
            <p class="text-sm text-(--color-text-muted)">
              <time datetime={data.generatedAt}>{measuredAtLabel}</time>
            </p>
          ) : (
            <p class="text-sm text-(--color-text-muted)">{t('quality.noSnapshot')}</p>
          )}
        </div>

        <div class="w-full sm:w-auto sm:min-w-64">
          <select
            id="lighthouse-page-filter"
            data-page-select
            aria-label={t('quality.filterLabel')}
            class="home-body-text w-full rounded-lg border border-(--color-border) bg-(--color-bg) px-3 py-2"
          >
            {pages.map(page => (
              <option value={page.path} selected={page.path === selectedPage?.path}>
                {page.path}
              </option>
            ))}
          </select>
        </div>
      </header>

      <div class="mt-6 flex flex-col gap-4">
        <div class="grid gap-2 sm:grid-cols-2 xl:grid-cols-4">
          {scoreDefinitions.map(score => (
            <Surface class="p-3">
              <p class="text-xs font-medium tracking-wide text-(--color-text-muted) uppercase">
                {score.label}
              </p>
              <p
                data-score-badge={score.key}
                class={`mt-2 inline-flex rounded-full px-3 py-1 text-sm font-semibold ring-1 ring-inset ${scoreClassName(selectedPage?.[score.key] ?? null)}`}
              >
                {selectedPage?.[score.key] ?? t('quality.na')}
              </p>
            </Surface>
          ))}
        </div>

        <Surface as="details" class="p-3">
          <summary class="-m-3 list-item cursor-pointer rounded-xl p-3 text-sm font-medium text-(--color-text)">
            {t('quality.details')}
          </summary>

          <div class="mt-3 grid gap-4 lg:grid-cols-2">
            <dl class="grid gap-y-2">
              <div class="flex items-center justify-between gap-3">
                <dt class="text-sm font-medium text-(--color-text)">{t('quality.path')}</dt>
                <dd class="text-sm text-(--color-text-muted)" data-page-path>
                  {selectedPage?.path ?? t('quality.na')}
                </dd>
              </div>

              <div class="flex items-center justify-between gap-3">
                <dt class="text-sm font-medium text-(--color-text)">{t('quality.url')}</dt>
                <dd class="truncate text-sm text-(--color-text-muted)" data-page-url>
                  {selectedPage?.url ?? t('quality.na')}
                </dd>
              </div>

              <div class="flex items-center justify-between gap-3">
                <dt class="text-sm font-medium text-(--color-text)">{t('quality.measured')}</dt>
                <dd class="text-sm text-(--color-text-muted)" data-page-time>
                  {formatTimestamp(selectedPage?.generatedAt ?? null)}
                </dd>
              </div>

              <div class="flex items-center justify-between gap-3">
                <dt class="text-sm font-medium text-(--color-text)">{t('quality.runs')}</dt>
                <dd class="text-sm text-(--color-text-muted)" data-page-runs>
                  {selectedPage?.runs ?? t('quality.na')}
                </dd>
              </div>
            </dl>

            <dl class="grid gap-y-2">
              {metricDefinitions.map(metric => (
                <div class="flex items-center justify-between gap-3">
                  <dt class="text-sm font-medium text-(--color-text)" title={metric.fullLabel}>
                    {metric.label}
                  </dt>
                  <dd class="text-sm text-(--color-text-muted)" data-metric-value={metric.key}>
                    {selectedPage?.[metric.key] ?? t('quality.na')}
                  </dd>
                </div>
              ))}
            </dl>
          </div>
        </Surface>
      </div>

      {!hasData && <p class="mt-6 text-sm text-(--color-text-muted)">{t('quality.noResults')}</p>}
    </Surface>
  )
}
