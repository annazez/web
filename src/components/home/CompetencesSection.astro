---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { Icon } from 'astro-icon/components';
import Surface from '../ui/Surface.astro';
import { getCollection } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = await useTranslations(lang);
const competencesHref = `/${lang}/competences/`;
const moreLabel = t('competences.more');

const competences = (await getCollection('competences'))
  .filter(c => c.id.startsWith(`${lang}/`))
  .sort((a, b) => a.data.order - b.data.order);
---

<Surface as="section">
  <div class="flex flex-col gap-4">
    <header class="flex flex-col gap-3 border-b border-(--color-border) pb-4">
      <div class="flex items-center justify-between gap-4">
        <h2>{t('competences.title')}</h2>
        <a href={competencesHref} class="home-section-more-link">
          <span>{moreLabel}</span>
          <Icon name="lucide:arrow-right" class="home-section-more-link-icon" />
        </a>
      </div>
      <p class="home-body-text">
        {t('competences.subtitle')}
      </p>
    </header>

    <div class="flex flex-col gap-3 pt-2">
      {
        competences.map(competence => (
          <Surface as="details" class="group transition-colors hover:border-(--color-brand)">
            <summary class="flex cursor-pointer list-none items-center justify-between rounded-xl p-4 text-base font-medium text-(--color-text) outline-none focus-visible:ring-2 focus-visible:ring-(--color-brand) [&::-webkit-details-marker]:hidden">
              <div class="flex items-center gap-3">
                <Icon
                  name={competence.data.icon}
                  class="h-5 w-5 text-(--color-brand) opacity-70 transition-opacity group-hover:opacity-100"
                />
                {competence.data.title}
              </div>
              <Icon
                name="lucide:chevron-down"
                class="h-5 w-5 text-(--color-text-muted) transition-transform group-open:rotate-180"
              />
            </summary>
            <div class="border-t border-(--color-border) px-4 py-3 text-sm text-(--color-text-muted)">
              {competence.data.desc}
            </div>
          </Surface>
        ))
      }
    </div>
  </div>
</Surface>
