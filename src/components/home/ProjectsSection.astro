---
/**
 * SECTION CONVENTION:
 * This component self-wraps its "card chrome" (background, border, shadow).
 * This ensures visual consistency across the site and simplifies page layouts.
 */
import type { CollectionEntry } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { Icon } from 'astro-icon/components';
import ProjectCard from './ProjectCard.astro';

interface Props {
  projectArticles: CollectionEntry<'projects'>[];
}

const { projectArticles } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const projectsHref = `/${lang}/projects/`;
const moreLabel = t('projects.more');

const featuredProjects = projectArticles
  .filter(article => article.data.featured)
  .sort((a, b) => {
    const orderA = a.data.order ?? Infinity;
    const orderB = b.data.order ?? Infinity;
    if (orderA !== orderB) return orderA - orderB;
    return b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
  });
---

<section
  class="overflow-hidden rounded-2xl border border-(--color-border) bg-(--color-bg-surface) px-4 py-5 shadow-sm sm:px-5"
>
  <project-carousel class="flex flex-col gap-4">
    <header class="flex flex-col gap-3 border-b border-(--color-border) pb-4">
      <div class="flex items-center justify-between gap-4">
        <h2>{t('projects.title')}</h2>
        <a href={projectsHref} class="home-section-more-link">
          <span>{moreLabel}</span>
          <Icon name="lucide:arrow-right" class="home-section-more-link-icon" />
        </a>
      </div>
      <p class="home-body-text">
        {t('projects.subtitle')}
      </p>
    </header>

    <div class="group relative">
      <div
        class="projects-track flex w-full snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth pb-2 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
      >
        {
          featuredProjects.map(project => {
            return (
              <div class="w-full flex-none shrink-0 snap-center">
                <ProjectCard
                  title={project.data.title}
                  description={project.data.homeDescription || project.data.summary}
                  articleSlug={project.data.slug}
                  tags={project.data.tags}
                  repo={project.data.repo}
                  website={project.data.website}
                />
              </div>
            );
          })
        }
      </div>

      <div class="mt-2 flex items-center justify-between px-2">
        <button
          class="nav-btn prev p-2 text-(--color-text-muted) transition-colors hover:text-(--color-brand) disabled:opacity-30 disabled:hover:text-(--color-text-muted)"
          aria-label={t('projects.carousel.previous')}
        >
          <Icon name="lucide:arrow-left" class="size-5 sm:size-6" />
        </button>
        <div class="dots flex flex-1 justify-center gap-3" aria-hidden="true">
          {
            featuredProjects.map(() => (
              <button
                tabindex="-1"
                class="dot size-2.5 rounded-full bg-(--color-border) transition-colors data-[active=true]:bg-(--color-brand)"
              />
            ))
          }
        </div>
        <button
          class="nav-btn next p-2 text-(--color-text-muted) transition-colors hover:text-(--color-brand) disabled:opacity-30 disabled:hover:text-(--color-text-muted)"
          aria-label={t('projects.carousel.next')}
        >
          <Icon name="lucide:arrow-right" class="size-5 sm:size-6" />
        </button>
      </div>
    </div>
  </project-carousel>
</section>

<script src="../../scripts/project-carousel.ts"></script>
