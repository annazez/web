---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import ProjectCard from './ProjectCard.astro';

interface Project {
  title: string;
  description: string;
  tags: string[];
  repo?: string;
  website?: string;
  image?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projects: Project[] = [
  {
    title: 'Telperion Web',
    description: t('projects.telperion.description'),
    tags: ['Astro', 'React', 'Tailwind', 'TypeScript', 'i18n'],
    website: 'https://telperion.cz',
    repo: 'https://github.com/annazez/telperion-web',
  },
  {
    title: 'Personal Web',
    description: t('projects.personalWeb.description'),
    tags: ['Astro', 'Tailwind', 'SSG', 'Minimal'],
    repo: 'https://codeberg.org/annazez/personal-web',
  },
];
---

<section class="flex flex-col gap-6">
  <header class="flex flex-col gap-2">
    <h2 class="home-section-title font-medium">
      {t('projects.title')}
    </h2>
    <p class="home-subtle-text">
      {t('projects.subtitle')}
    </p>
  </header>

  <div class="projects-grid">
    {projects.map(project => <ProjectCard {...project} />)}
  </div>
</section>

<style>
  .projects-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
