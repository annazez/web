---
import type { CollectionEntry } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import ProjectCard from './ProjectCard.astro';

interface Props {
  projectArticles: CollectionEntry<'projects'>[];
}

interface Project {
  slug: string;
  title: string;
  description: string;
  tags: string[];
  repo?: string;
  website?: string;
  image?: string;
}

const { projectArticles } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const articleBySlug = new Map(projectArticles.map(article => [article.data.slug, article.data]));

const projects: Project[] = [
  {
    slug: 'telperion',
    title: 'Telperion Web',
    description: t('projects.telperion.description'),
    tags: ['Astro', 'React', 'Tailwind', 'TypeScript', 'i18n'],
    website: 'https://telperion.cz',
    repo: 'https://github.com/annazez/telperion-web',
  },
  {
    slug: 'personal-web',
    title: 'Personal Web',
    description: t('projects.personalWeb.description'),
    tags: ['Astro', 'Tailwind', 'SSG', 'Minimal'],
    repo: 'https://codeberg.org/annazez/personal-web',
  },
];
---

<section class="flex flex-col gap-6">
  <header class="flex flex-col gap-2">
    <h2 class="home-section-title font-medium">
      {t('projects.title')}
    </h2>
    <p class="home-subtle-text">
      {t('projects.subtitle')}
    </p>
  </header>

  <div class="projects-grid">
    {
      projects.map(project => {
        const article = articleBySlug.get(project.slug);

        return (
          <ProjectCard
            title={project.title}
            description={project.description}
            articleSlug={article?.slug}
            tags={article?.tags ?? project.tags}
            repo={project.repo}
            website={project.website}
            image={project.image}
          />
        );
      })
    }
  </div>
</section>

<style>
  .projects-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }
</style>
