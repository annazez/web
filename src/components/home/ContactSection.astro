---
/**
 * SECTION CONVENTION:
 * This component self-wraps its "card chrome" (background, border, shadow).
 * This ensures visual consistency across the site and simplifies page layouts.
 */
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { identity } from '../../data/identity';
import { toSafeExternalUrl } from '../../security/external-links';
import Surface from '../ui/Surface.astro';

const lang = getLangFromUrl(Astro.url);
const t = await useTranslations(lang);

const signalUrl = toSafeExternalUrl(identity.signal);
---

<Surface as="section">
  <div class="flex flex-col gap-4">
    <header class="flex flex-col gap-3 border-b border-(--color-border) pb-4">
      <h2>{t('home.contactTitle')}</h2>
      <p class="home-body-text">{t('home.contact')}</p>
    </header>
    <div class="pt-2">
      <div
        class="grid w-full grid-cols-1 divide-y divide-(--color-border) overflow-hidden rounded-xl border border-(--color-border) sm:w-fit sm:grid-cols-2 sm:divide-x sm:divide-y-0 sm:rounded-full"
      >
        <a
          href={`mailto:${identity.email}`}
          class="flex items-center justify-center gap-2 px-6 py-3 font-medium text-(--color-text-secondary) transition-colors hover:bg-(--color-bg-surface-elevated) hover:text-(--color-brand) focus-visible:outline-2 focus-visible:outline-offset-2"
        >
          <Icon name="lucide:mail" class="size-5 shrink-0" aria-hidden="true" />
          <span>{t('home.contactCta')}</span>
        </a>
        {
          signalUrl && (
            <a
              href={signalUrl}
              target="_blank"
              rel="me noopener noreferrer"
              class="flex items-center justify-center gap-2 px-6 py-3 font-medium text-(--color-text-secondary) transition-colors hover:bg-(--color-bg-surface-elevated) hover:text-(--color-brand) focus-visible:outline-2 focus-visible:outline-offset-2"
            >
              <Icon
                name="lucide:message-circle-dashed"
                class="size-5 shrink-0"
                aria-hidden="true"
              />
              <span>{t('home.social.signal')}</span>
            </a>
          )
        }
      </div>
    </div>
  </div>
</Surface>
