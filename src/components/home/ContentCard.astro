---
import { toSafeExternalUrl } from '../../security/external-links';
import Surface from '../ui/Surface.astro';

interface Props {
  title: string;
  description: string;
  link?: string;
  linkHref?: string;
}

const { title, description, link, linkHref } = Astro.props;
let href = linkHref || link;
let displayLink = link;

if (href?.startsWith('http://') || href?.startsWith('https://')) {
  const safeUrl = toSafeExternalUrl(href);
  if (safeUrl) {
    href = safeUrl;
  } else {
    displayLink = undefined;
  }
}

const isExternal = href && !href.startsWith('mailto:') && !href.startsWith('/');
---

<Surface as="li" class="flex flex-col">
  <h3>{title}</h3>
  <p class="home-body-text mt-2">{description}</p>
  {
    displayLink && (
      <a
        href={href}
        class="home-micro-label mt-3 inline-block transition-colors hover:text-(--color-brand)"
        {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      >
        {displayLink}
      </a>
    )
  }
</Surface>
