---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { Icon } from 'astro-icon/components';
import { toSafeExternalUrl } from '../../security/external-links';

interface Props {
  title: string;
  description?: string;
  summary?: string;
  articleSlug?: string;
  tags: string[];
  repo?: string;
  website?: string;
}

const { title, description, summary, articleSlug, tags, repo, website } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const safeWebsite = toSafeExternalUrl(website);
const safeRepo = toSafeExternalUrl(repo);
---

<article
  class="flex h-full min-w-0 flex-col gap-5 rounded-lg border border-zinc-200 bg-zinc-50 p-6 transition-colors hover:border-zinc-300 hover:shadow-md sm:p-8 dark:border-zinc-800 dark:bg-zinc-900 dark:hover:border-zinc-700 dark:hover:shadow-zinc-900/20"
>
  <div class="flex flex-1 flex-col gap-2">
    <div class="flex items-start justify-between">
      <h3 class="home-card-title">{title}</h3>
    </div>

    {description && <p class="home-body-text">{description}</p>}

    {
      summary && (
        <p class="home-micro-copy overflow-hidden text-ellipsis whitespace-nowrap">{summary}</p>
      )
    }

    <div
      class="mt-auto flex flex-nowrap gap-2 overflow-x-auto overflow-y-hidden [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
    >
      {
        tags.map(tag => (
          <span class="home-tag-text inline-block rounded-full bg-zinc-100 px-3 py-1 font-medium whitespace-nowrap dark:bg-zinc-800">
            {tag}
          </span>
        ))
      }
    </div>
  </div>

  {
    (safeWebsite || safeRepo) && (
      <div
        class:list={[
          'mt-auto grid gap-2 border-t border-(--color-border) pt-3',
          safeWebsite && safeRepo ? 'grid-cols-2' : 'grid-cols-1',
        ]}
      >
        {safeWebsite && (
          <a
            href={safeWebsite}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${t('projects.visit')} ${title}`}
            class="flex w-full items-center justify-center gap-2 rounded-md bg-zinc-200 px-4 py-2.5 text-sm font-medium text-(--color-brand) transition-colors hover:bg-zinc-300 dark:bg-zinc-700 dark:hover:bg-zinc-600"
          >
            <Icon name="lucide:external-link" class="h-4 w-4" />
            {t('projects.visit')}
          </a>
        )}
        {safeRepo && (
          <a
            href={safeRepo}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${t('projects.source')} ${title}`}
            class="flex w-full items-center justify-center gap-2 rounded-md bg-zinc-100 px-4 py-2.5 text-sm font-medium text-(--color-text-secondary) transition-colors hover:bg-zinc-200 dark:bg-zinc-800 dark:hover:bg-zinc-700"
          >
            <Icon name="lucide:code-2" class="h-4 w-4" />
            {t('projects.source')}
          </a>
        )}
      </div>
    )
  }

  {
    articleSlug && (
      <a
        href={`/${lang}/projects/${articleSlug}/`}
        aria-label={`${t('readCaseStudy')} ${title}`}
        class="mt-2 flex w-full items-center justify-center gap-2 rounded-md border border-(--color-border) bg-zinc-50 px-4 py-2.5 text-sm font-medium text-(--color-text-secondary) transition-colors hover:bg-zinc-100 dark:bg-zinc-900 dark:hover:bg-zinc-800"
      >
        <Icon name="lucide:file-text" class="h-4 w-4" />
        {t('readCaseStudy')}
      </a>
    )
  }
</article>
