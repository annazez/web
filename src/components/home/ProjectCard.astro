---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  tags: string[];
  repo?: string;
  website?: string;
  image?: string;
}

const { title, description, tags, repo, website, image } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<article
  class="flex flex-col gap-4 rounded-lg border border-zinc-200 bg-zinc-50 p-6 transition-colors hover:border-zinc-300 hover:shadow-md dark:border-zinc-800 dark:bg-zinc-900 dark:hover:border-zinc-700 dark:hover:shadow-zinc-900/20"
>
  {image && <img src={image} alt={title} class="h-48 w-full rounded-md object-cover" />}

  <div class="flex flex-1 flex-col gap-3">
    <div class="flex items-start justify-between">
      <h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100">{title}</h3>
    </div>

    <p class="text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">{description}</p>

    <div class="flex flex-wrap gap-2">
      {
        tags.map(tag => (
          <span class="inline-block rounded-full bg-zinc-100 px-3 py-1 text-xs font-medium text-zinc-700 dark:bg-zinc-800 dark:text-zinc-300">
            {tag}
          </span>
        ))
      }
    </div>
  </div>

  <div class="mt-auto flex gap-2 border-t border-zinc-200 pt-4 dark:border-zinc-800">
    {
      website && (
        <a
          href={website}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${t('projects.visit')} ${title}`}
          class="flex items-center gap-2 rounded-md bg-zinc-200 px-3 py-2 text-xs font-semibold text-zinc-900 transition-colors hover:bg-zinc-300 dark:bg-zinc-700 dark:text-zinc-100 dark:hover:bg-zinc-600"
        >
          <Icon name="lucide:external-link" class="h-4 w-4" />
          {t('projects.visit')}
        </a>
      )
    }
    {
      repo && (
        <a
          href={repo}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${t('projects.source')} ${title}`}
          class="flex items-center gap-2 rounded-md bg-zinc-100 px-3 py-2 text-xs font-medium text-zinc-700 transition-colors hover:bg-zinc-200 dark:bg-zinc-800 dark:text-zinc-300 dark:hover:bg-zinc-700"
        >
          <Icon name="lucide:code-2" class="h-4 w-4" />
          {t('projects.source')}
        </a>
      )
    }
  </div>
</article>
