---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { Icon } from 'astro-icon/components';
import { toSafeExternalUrl } from '../../security/external-links';

interface Props {
  title: string;
  description?: string;
  summary?: string;
  articleSlug?: string;
  tags: string[];
  repo?: string;
  website?: string;
  as?: 'h2' | 'h3';
}

const {
  title,
  description,
  summary,
  articleSlug,
  tags,
  repo,
  website,
  as: Heading = 'h3',
} = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const safeWebsite = toSafeExternalUrl(website);
const safeRepo = toSafeExternalUrl(repo);
---

<article class="flex h-full min-w-0 flex-col gap-5">
  <div class="flex flex-1 flex-col gap-2">
    <div class="flex items-start justify-between">
      <Heading class="text-[1.625rem] leading-[1.15] font-medium tracking-[-0.02em]">
        {title}
      </Heading>
    </div>

    {description && <p class="home-body-text">{description}</p>}

    {summary && <p class="home-subtle-text wrap-break-word whitespace-normal">{summary}</p>}

    <div
      class="mt-auto flex flex-nowrap gap-2 overflow-x-auto overflow-y-hidden [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
    >
      {
        tags.map((tag: string) => (
          <span class="home-tag-text inline-block rounded-full bg-(--color-bg-surface-elevated) px-3 py-1 font-medium whitespace-nowrap">
            {tag}
          </span>
        ))
      }
    </div>
  </div>

  {
    (safeWebsite || safeRepo || articleSlug) && (
      <div class="mt-auto flex flex-col gap-2">
        {(safeWebsite || safeRepo) && (
          <div
            class:list={[
              'grid gap-2 border-t border-(--color-border) pt-3',
              safeWebsite && safeRepo ? 'grid-cols-2' : 'grid-cols-1',
            ]}
          >
            {safeWebsite && (
              <a
                href={safeWebsite}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${t('projects.visit')} ${title}`}
                class="flex w-full items-center justify-center gap-2 rounded-xl bg-(--color-border) px-4 py-2.5 text-sm font-medium text-(--color-brand) transition-colors hover:bg-[color-mix(in_srgb,var(--color-border),var(--color-brand)_10%)]"
              >
                <Icon name="lucide:external-link" class="h-4 w-4" />
                {t('projects.visit')}
              </a>
            )}
            {safeRepo && (
              <a
                href={safeRepo}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${t('projects.source')} ${title}`}
                class="flex w-full items-center justify-center gap-2 rounded-xl bg-(--color-bg-surface-elevated) px-4 py-2.5 text-sm font-medium text-(--color-text-secondary) transition-colors hover:bg-(--color-border)"
              >
                <Icon name="lucide:code-2" class="h-4 w-4" />
                {t('projects.source')}
              </a>
            )}
          </div>
        )}

        {articleSlug && (
          <a
            href={`/${lang}/projects/${articleSlug}/`}
            aria-label={`${t('readCaseStudy')} ${title}`}
            class="flex w-full items-center justify-center gap-2 rounded-xl border border-(--color-border) bg-(--color-bg-surface) px-4 py-2.5 text-sm font-medium text-(--color-text-secondary) transition-colors hover:bg-(--color-bg-surface-elevated)"
          >
            <Icon name="lucide:file-text" class="h-4 w-4" />
            {t('readCaseStudy')}
          </a>
        )}
      </div>
    )
  }
</article>
