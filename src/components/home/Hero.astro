---
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="flex flex-col gap-16">
  <header class="flex flex-col gap-4">
    <h1 class="home-display-title font-semibold">Anna Zezulka</h1>
    <p class="home-micro-label">
      {t('role.title')}
    </p>
  </header>
  <section class="home-body-text space-y-6">
    <p>{t('hero.manifesto')}</p>
    <p>{t('hero.minimalByDesign')}</p>
  </section>

  <ul class="home-social-links flex flex-wrap gap-x-6 gap-y-3">
    <li>
      <a
        href="https://www.linkedin.com/in/anna-zezulka-8956b9384"
        target="_blank"
        rel="me noopener noreferrer"
        class="flex items-center gap-2 whitespace-nowrap"
      >
        <Icon name="lucide:linkedin" class="size-5" />
        <span>LinkedIn</span>
      </a>
    </li>
    <li>
      <a
        href="https://github.com/annazez"
        target="_blank"
        rel="me noopener noreferrer"
        class="flex items-center gap-2 whitespace-nowrap"
      >
        <Icon name="lucide:github" class="size-5" />
        <span>GitHub</span>
      </a>
    </li>
    <li>
      <a href="mailto:anna.zezulka@proton.me" class="flex items-center gap-2 whitespace-nowrap">
        <Icon name="lucide:mail" class="size-5" />
        <span>Email</span>
      </a>
    </li>
  </ul>
</div>
