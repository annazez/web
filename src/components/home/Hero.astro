---
import { Image } from 'astro:assets';
import avatar from '../../assets/avatar.png';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { Icon } from 'astro-icon/components';
import { identity } from '../../data/identity';
import { toSafeExternalUrl } from '../../security/external-links';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const siteName = t('site.name');

const linkedinUrl = toSafeExternalUrl(identity.linkedin);
const orcidUrl = toSafeExternalUrl(identity.orcid);
const githubUrl = toSafeExternalUrl(identity.github);
const codebergUrl = toSafeExternalUrl(identity.codeberg);
const keyoxideUrl = toSafeExternalUrl(identity.keyoxide);
---

<div class="flex flex-col gap-8">
  <header class="flex flex-col gap-6 sm:flex-row sm:items-center">
    <Image
      src={avatar}
      alt={siteName}
      width={128}
      height={128}
      loading="eager"
      fetchpriority="high"
      class="size-24 shrink-0 rounded-full border border-(--color-border) object-cover sm:size-32"
    />
    <div class="flex flex-col gap-2 sm:gap-4">
      <h1>{siteName}</h1>
      <p class="home-body-text">
        {t('role.title')}
      </p>
      <div class="home-social-links flex items-center gap-4">
        {
          linkedinUrl && (
            <a
              href={linkedinUrl}
              target="_blank"
              rel="me noopener noreferrer"
              aria-label="LinkedIn"
            >
              <Icon name="lucide:linkedin" class="size-5" />
            </a>
          )
        }
        {
          orcidUrl && (
            <a href={orcidUrl} target="_blank" rel="me noopener noreferrer" aria-label="ORCID">
              <Icon name="simple-icons:orcid" class="size-5" />
            </a>
          )
        }
        {
          githubUrl && (
            <a href={githubUrl} target="_blank" rel="me noopener noreferrer" aria-label="Github">
              <Icon name="simple-icons:github" class="size-5" />
            </a>
          )
        }
        {
          codebergUrl && (
            <a
              href={codebergUrl}
              target="_blank"
              rel="me noopener noreferrer"
              aria-label="Codeberg"
            >
              <Icon name="simple-icons:codeberg" class="size-5" />
            </a>
          )
        }
        {
          keyoxideUrl && (
            <a
              href={keyoxideUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={t('home.social.keyoxide')}
              title={t('home.social.keyoxide')}
            >
              <Icon name="lucide:shield-check" class="size-5" />
            </a>
          )
        }
      </div>
    </div>
  </header>
  <section class="home-body-text flex flex-col gap-4">
    <p>{t('hero.manifesto')}</p>
  </section>
</div>
