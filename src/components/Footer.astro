---
import { Icon } from 'astro-icon/components';
// TODO: Add PGP key
---

<footer class="flex items-center gap-6 border-t border-zinc-200 pt-8">
  <a
    href="https://github.com/annazez"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="GitHub"
    class="text-zinc-400 transition-colors hover:text-zinc-900"
    ><Icon name="lucide:github" class="h-5 w-5" /></a
  >
  <a
    href="mailto:anna.zezulka@proton.me"
    aria-label="Email"
    class="text-zinc-400 transition-colors hover:text-zinc-900"
    ><Icon name="lucide:mail" class="h-5 w-5" /></a
  >
  <a
    href="/humans.txt"
    aria-label="Humans.txt"
    class="text-zinc-400 transition-colors hover:text-zinc-900"
    ><Icon name="lucide:file-text" class="h-5 w-5" /></a
  >
</footer>
