---
import { getCollection, render } from 'astro:content';
import BackLink from '../../../components/BackLink.astro';
import Footer from '../../../components/ui/Footer.astro';
import LanguagePicker from '../../../components/ui/LanguagePicker.astro';
import Layout from '../../../layouts/Layout.astro';

const lang = 'en' as const;

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => data.lang === 'en');

  return projects.map(project => ({
    params: { slug: project.data.slug },
  }));
}

const { slug } = Astro.params;
const projectEntry = (
  await getCollection('projects', ({ data }) => data.lang === lang && data.slug === slug)
)[0];

if (!projectEntry) {
  throw new Error(`Project case study not found for slug "${slug}" in locale "${lang}".`);
}

const { Content } = await render(projectEntry);
const { title, summary, publishedAt, tags } = projectEntry.data;
const canonicalUrl = new URL(`/en/projects/${slug}/`, Astro.site ?? Astro.url).toString();
const publishedLabel = publishedAt.toLocaleDateString('en-US', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<Layout title={title} description={summary} lang={lang}>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" href="/en/rss.xml" />
    <link rel="alternate" type="application/rss+xml" href="/cs/rss.xml" />
  </Fragment>

  <LanguagePicker />

  <main id="main-content" class="mx-auto flex max-w-2xl flex-col gap-20 px-6 py-32">
    <BackLink href="/en/" />

    <article class="flex flex-col gap-10">
      <header class="flex flex-col gap-4">
        <h1 class="home-display-title font-semibold">{title}</h1>
        <time datetime={publishedAt.toISOString()} class="home-micro-copy">{publishedLabel}</time>

        <ul class="flex flex-wrap gap-2">
          {
            tags.map(tag => (
              <li class="home-tag-text inline-block rounded-full bg-zinc-100 px-2 py-1 dark:bg-zinc-800">
                {tag}
              </li>
            ))
          }
        </ul>
      </header>

      <section class="case-study-content home-body-text">
        <Content />
      </section>
    </article>

    <Footer lang={lang} />
  </main>
</Layout>

<style>
  .case-study-content :global(p) {
    margin-bottom: 1rem;
  }

  .case-study-content :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
