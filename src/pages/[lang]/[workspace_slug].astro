---
import { getEntry } from 'astro:content';
import BackLink from '../../components/BackLink.astro';
import Footer from '../../components/ui/Footer.astro';
import LanguagePicker from '../../components/ui/LanguagePicker.astro';
import { defaultLang, getValidLanguageCode, routes } from '../../i18n/dictionary';
import { useTranslations } from '../../i18n/utils';
import ContentCard from '../../components/home/ContentCard.astro';
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'en', workspace_slug: routes.workspace.en } },
    { params: { lang: 'cs', workspace_slug: routes.workspace.cs } },
  ];
}

const currentLang = getValidLanguageCode(Astro.params.lang);
const t = useTranslations(currentLang);

let entry;
if (currentLang === defaultLang) {
  entry = await getEntry('workspace', currentLang);
} else {
  const [currentEntry, fallbackEntry] = await Promise.all([
    getEntry('workspace', currentLang),
    getEntry('workspace', defaultLang),
  ]);
  entry = currentEntry ?? fallbackEntry;
}

if (!entry) {
  throw new Error(
    `Missing required "workspace" content for both "${currentLang}" and fallback "${defaultLang}".`
  );
}

const { title, intro, categories } = entry.data;
---

<Layout title={t('seo.workspace')} lang={currentLang}>
  <LanguagePicker />

  <main id="main-content" class="mx-auto flex max-w-2xl flex-col gap-8 px-6 py-16">
    <BackLink href={`/${currentLang}/`} />

    <header class="flex flex-col gap-4">
      <h1 class="home-display-title">{title}</h1>
      <p class="home-body-text">{intro}</p>
    </header>

    <section class="flex flex-col gap-8" aria-label={title}>
      {
        categories.map(section => (
          <section
            class="flex flex-col gap-3"
            aria-labelledby={`workspace-${section.category.toLowerCase()}`}
          >
            <h2
              id={`workspace-${section.category.toLowerCase()}`}
              class="home-section-title font-medium"
            >
              {section.label}
            </h2>

            <ul class="flex flex-col gap-4">
              {section.items.map(item => (
                <ContentCard title={item.name} description={item.description} link={item.link} />
              ))}
            </ul>
          </section>
        ))
      }
    </section>

    <Footer lang={currentLang} />
  </main>
</Layout>
