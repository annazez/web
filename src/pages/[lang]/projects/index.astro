---
import Layout from '../../../layouts/Layout.astro';
import BackLink from '../../../components/BackLink.astro';
import ProjectCard from '../../../components/home/ProjectCard.astro';
import Footer from '../../../components/ui/Footer.astro';
import Surface from '../../../components/ui/Surface.astro';
import { getValidLanguageCode, supportedLangs } from '../../../i18n/dictionary';
import { useTranslations } from '../../../i18n/utils';
import { getProjects } from '../../../lib/projects';

export function getStaticPaths() {
  return supportedLangs.map(lang => ({ params: { lang } }));
}

const currentLang = getValidLanguageCode(Astro.params.lang);
const t = await useTranslations(currentLang);
const projectArticles = await getProjects(currentLang);
---

<Layout title={t('projects.title')} lang={currentLang}>
  <Fragment slot="head">
    <link rel="alternate" type="application/rss+xml" href="/en/rss.xml" />
    <link rel="alternate" type="application/rss+xml" href="/cs/rss.xml" />
  </Fragment>

  <main id="main-content" class="mx-auto flex max-w-2xl flex-col gap-8 px-6 py-16">
    <BackLink href={`/${currentLang}/`} />

    <header class="flex flex-col gap-3">
      <h1>{t('projects.title')}</h1>
      <p class="home-body-text max-w-2xl">{t('projects.subtitle')}</p>
    </header>

    <Surface as="section" class="flex flex-col gap-4">
      {
        projectArticles.map(article => (
          <ProjectCard
            title={article.data.title}
            summary={article.data.summary}
            articleSlug={article.data.slug}
            tags={article.data.tags}
            website={article.data.website}
            repo={article.data.repo}
            as="h2"
          />
        ))
      }
    </Surface>

    <Footer lang={currentLang} />
  </main>
</Layout>
