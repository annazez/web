---
import { getCollection, render } from 'astro:content';
import BackLink from '../../../components/BackLink.astro';
import Footer from '../../../components/ui/Footer.astro';
import LanguagePicker from '../../../components/ui/LanguagePicker.astro';
import Layout from '../../../layouts/Layout.astro';
import { getValidLanguageCode } from '../../../i18n/dictionary';
import { getStaticPaths } from './_slug.static-paths';

export { getStaticPaths };

const currentLang = getValidLanguageCode(Astro.params.lang);
const { slug } = Astro.params;
const projectEntry = (
  await getCollection('projects', ({ data }) => data.lang === currentLang && data.slug === slug)
)[0];

if (!projectEntry) {
  throw new Error(`Project case study not found for slug "${slug}" in locale "${currentLang}".`);
}

const { Content } = await render(projectEntry);
const { title, summary, publishedAt, tags } = projectEntry.data;
const canonicalUrl = new URL(
  `/${currentLang}/projects/${slug}/`,
  Astro.site ?? Astro.url
).toString();
const publishedLabel = publishedAt.toLocaleDateString(currentLang === 'cs' ? 'cs-CZ' : 'en-US', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<Layout title={title} description={summary} lang={currentLang}>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" href="/en/rss.xml" />
    <link rel="alternate" type="application/rss+xml" href="/cs/rss.xml" />
  </Fragment>

  <LanguagePicker />

  <main id="main-content" class="mx-auto flex max-w-2xl flex-col gap-4 px-6 py-16">
    <BackLink href={`/${currentLang}/`} />

    <article class="flex flex-col gap-8">
      <header class="flex flex-col gap-4">
        <h1>{title}</h1>
        <time datetime={publishedAt.toISOString()} class="home-micro-copy">{publishedLabel}</time>

        <ul class="flex flex-wrap gap-2">
          {
            tags.map(tag => (
              <li class="home-tag-text inline-block rounded-full bg-zinc-100 px-2 py-1 dark:bg-zinc-800">
                {tag}
              </li>
            ))
          }
        </ul>
      </header>

      <section class="case-study-content home-body-text">
        <Content />
      </section>
    </article>

    <Footer lang={currentLang} />
  </main>
</Layout>

<style>
  .case-study-content :global(h1),
  .case-study-content :global(h2),
  .case-study-content :global(h3),
  .case-study-content :global(h4),
  .case-study-content :global(h5),
  .case-study-content :global(h6) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .case-study-content :global(h1:first-child),
  .case-study-content :global(h2:first-child),
  .case-study-content :global(h3:first-child),
  .case-study-content :global(h4:first-child),
  .case-study-content :global(h5:first-child),
  .case-study-content :global(h6:first-child) {
    margin-top: 0;
  }

  .case-study-content :global(p) {
    margin-bottom: 1rem;
  }

  .case-study-content :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
