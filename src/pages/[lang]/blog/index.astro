---
import Layout from '../../../layouts/Layout.astro';
import LanguagePicker from '../../../components/ui/LanguagePicker.astro';
import BackLink from '../../../components/BackLink.astro';
import Footer from '../../../components/ui/Footer.astro';
import Surface from '../../../components/ui/Surface.astro';
import { getValidLanguageCode, supportedLangs } from '../../../i18n/dictionary';
import { useTranslations } from '../../../i18n/utils';
import { getBlogPosts } from '../../../lib/blog';

export function getStaticPaths() {
  return supportedLangs.map(lang => ({ params: { lang } }));
}

const currentLang = getValidLanguageCode(Astro.params.lang);
const t = useTranslations(currentLang);
const blogPosts = await getBlogPosts(currentLang);
---

<Layout title={t('blog.title')} lang={currentLang}>
  <Fragment slot="head">
    <link rel="alternate" type="application/rss+xml" href="/en/rss.xml" />
    <link rel="alternate" type="application/rss+xml" href="/cs/rss.xml" />
  </Fragment>

  <LanguagePicker />

  <main id="main-content" class="mx-auto flex max-w-2xl flex-col gap-8 px-6 py-16">
    <BackLink href={`/${currentLang}/`} />

    <header class="flex flex-col gap-3">
      <h1>{t('blog.title')}</h1>
      <p class="home-body-text max-w-2xl">{t('blog.subtitle')}</p>
    </header>

    <Surface as="section" class="flex flex-col gap-4">
      {
        blogPosts.length > 0 ? (
          blogPosts.map(post => (
            <article class="flex flex-col gap-2 rounded-lg border border-(--color-border) p-4 transition-colors hover:bg-(--color-surface-hover)">
              <div class="flex items-center justify-between gap-4">
                <h2 class="text-lg font-medium text-(--color-text)">
                  <a
                    href={`/${currentLang}/blog/${post.data.slug}`}
                    class="focus-ring relative after:absolute after:inset-0"
                  >
                    {post.data.title}
                  </a>
                </h2>
                <time
                  class="text-sm text-(--color-text-muted)"
                  datetime={post.data.publishedAt.toISOString()}
                >
                  {post.data.publishedAt.toLocaleDateString(
                    currentLang === 'cs' ? 'cs-CZ' : 'en-US',
                    {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    }
                  )}
                </time>
              </div>
              <p class="text-(--color-text-muted)">{post.data.summary}</p>
            </article>
          ))
        ) : (
          <div class="flex flex-col items-center justify-center gap-4 py-8 text-center text-(--color-text-muted)">
            <p>{t('blog.empty')}</p>
          </div>
        )
      }
    </Surface>

    <Footer lang={currentLang} />
  </main>
</Layout>
