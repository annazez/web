---
import { render } from 'astro:content';
import BackLink from '../../../components/BackLink.astro';
import Footer from '../../../components/ui/Footer.astro';
import LanguagePicker from '../../../components/ui/LanguagePicker.astro';
import Layout from '../../../layouts/Layout.astro';
import { getValidLanguageCode, supportedLangs, type LanguageCode } from '../../../i18n/dictionary';
import { localeFor } from '../../../i18n/utils';
import { getBlogPostBySlug, getAllBlogPosts } from '../../../lib/blog';

export async function getStaticPaths() {
  const paths: Array<{ params: { lang: LanguageCode; slug: string } }> = [];

  const allPosts = await getAllBlogPosts();

  for (const post of allPosts) {
    if (supportedLangs.includes(post.data.lang as LanguageCode)) {
      paths.push({ params: { lang: post.data.lang as LanguageCode, slug: post.data.slug } });
    }
  }

  return paths;
}

const currentLang = getValidLanguageCode(Astro.params.lang);
const { slug } = Astro.params;
const postEntry = await getBlogPostBySlug(slug as string, currentLang);

if (!postEntry) {
  throw new Error(`Blog post not found for slug "${slug}" in locale "${currentLang}".`);
}

const { Content } = await render(postEntry);
const { title, summary, publishedAt, tags, ogImage } = postEntry.data;
const publishedLabel = publishedAt.toLocaleDateString(localeFor(currentLang), {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<Layout title={title} description={summary} lang={currentLang} ogImage={ogImage}>
  <Fragment slot="head">
    <link rel="alternate" type="application/rss+xml" href="/en/rss.xml" />
    <link rel="alternate" type="application/rss+xml" href="/cs/rss.xml" />
  </Fragment>

  <LanguagePicker />

  <main id="main-content" class="mx-auto flex max-w-2xl flex-col gap-4 px-6 py-16">
    <BackLink href={`/${currentLang}/blog`} />

    <article class="flex flex-col gap-8">
      <header class="flex flex-col gap-4">
        <h1>{title}</h1>
        <time datetime={publishedAt.toISOString()} class="home-micro-copy">{publishedLabel}</time>

        {
          tags && tags.length > 0 && (
            <ul class="flex flex-wrap gap-2">
              {tags.map((tag: string) => (
                <li class="home-tag-text inline-block rounded-full bg-(--color-bg-surface-elevated) px-2 py-1">
                  {tag}
                </li>
              ))}
            </ul>
          )
        }
      </header>

      <section class="blog-post-content home-body-text">
        <Content />
      </section>
    </article>

    <Footer lang={currentLang} />
  </main>
</Layout>

<style>
  .blog-post-content :global(h1),
  .blog-post-content :global(h2),
  .blog-post-content :global(h3),
  .blog-post-content :global(h4),
  .blog-post-content :global(h5),
  .blog-post-content :global(h6) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .blog-post-content :global(h1:first-child),
  .blog-post-content :global(h2:first-child),
  .blog-post-content :global(h3:first-child),
  .blog-post-content :global(h4:first-child),
  .blog-post-content :global(h5:first-child),
  .blog-post-content :global(h6:first-child) {
    margin-top: 0;
  }

  .blog-post-content :global(p) {
    margin-bottom: 1rem;
  }

  .blog-post-content :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
