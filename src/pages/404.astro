---
import Layout from '../layouts/Layout.astro';
import { defaultLang } from '../i18n/dictionary';
import { useTranslations } from '../i18n/utils';
import { Icon } from 'astro-icon/components';
import { languageEntries } from '../i18n/dictionary';
import ThemeToggle from '../components/ui/ThemeToggle.astro';

const t = await useTranslations(defaultLang);
---

<Layout title={t('seo.404')}>
  <div
    class="z-20 mx-auto w-full max-w-2xl px-6 pt-4 sm:absolute sm:top-8 sm:right-8 sm:mx-0 sm:w-auto sm:max-w-none sm:p-0"
  >
    <ThemeToggle
      className="flex min-h-11 w-full items-center justify-between rounded-xl border border-(--color-border) bg-(--color-bg) px-3 py-2 text-(--color-text-muted) shadow-sm transition-colors duration-200 hover:text-(--color-brand) sm:w-32"
    />
  </div>
  <main
    id="main-content"
    class="mx-auto flex max-w-2xl flex-col items-center justify-center px-6 py-32 text-center"
  >
    <h1>404</h1>

    <p class="home-micro-label mt-4">{t('404.title')}</p>

    <p class="home-body-text mt-6">
      {t('404.message')}
    </p>

    <p class="home-body-text mt-6">{t('404.languagePrompt')}</p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      {
        languageEntries.map(([code, label]) => (
          <a
            href={`/${code}/`}
            class="home-action-text rounded-md border border-(--color-border) px-6 py-2 transition-colors hover:bg-(--color-bg-surface)"
          >
            {label}
          </a>
        ))
      }

      <a
        href={`/${defaultLang}/`}
        class="home-action-text flex items-center gap-2 rounded-md border border-(--color-border) px-6 py-2 transition-colors hover:bg-(--color-bg-surface)"
      >
        <Icon name="lucide:arrow-left" class="size-4" />
        <span>{t('404.return')}</span>
      </a>
    </div>
  </main>
</Layout>
