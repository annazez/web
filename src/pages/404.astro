---
import Layout from '../layouts/Layout.astro';
import { defaultLang } from '../i18n/dictionary';
import { Icon } from 'astro-icon/components';
---

<Layout title="404: Not Found">
  <main
    id="main-content"
    class="mx-auto flex min-h-[80vh] max-w-2xl flex-col items-center justify-center px-6 text-center"
  >
    <h1 class="text-9xl font-light tracking-tight text-zinc-900 dark:text-zinc-50">404</h1>

    <p class="mt-4 font-mono text-sm tracking-widest text-zinc-500 uppercase dark:text-zinc-400">
      System Node Not Found
    </p>

    <p class="mt-6 text-zinc-600 dark:text-zinc-400">
      The architecture you are looking for has been moved or doesn't exist in this dimension.
    </p>

    <a
      href={`/${defaultLang}/`}
      class="mt-10 flex items-center gap-2 rounded-md border border-zinc-200 px-6 py-2 text-sm font-medium text-zinc-900 transition-colors hover:bg-zinc-100 dark:border-zinc-800 dark:text-zinc-100 dark:hover:bg-zinc-900"
    >
      <Icon name="lucide:arrow-left" class="size-4" />
      <span>Return</span>
    </a>
  </main>
</Layout>
